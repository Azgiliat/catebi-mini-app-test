{
  "name": "catebi",
  "private": true,
  "packageManager": "yarn@4.12.0",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev:web": "yarn workspace @catebi/web dev",
    "dev:api": "yarn workspace @catebi/api dev",
    "dev:firebase": "yarn build:api && NO_UPDATE_NOTIFIER=1 firebase emulators:start --import ./saved-data --export-on-exit ./saved-data --project catebydemo --config firebase.dev.json --only auth,firestore,functions",
    "build:web": "yarn workspace @catebi/web build",
    "build:api": "yarn workspace @catebi/api build",
    "build": "yarn build:web && yarn build:api",
    "lint:web": "yarn workspace @catebi/web lint",
    "lint": "yarn lint:web",
    "firebase": "NO_UPDATE_NOTIFIER=1 firebase",
    "deploy": "NO_UPDATE_NOTIFIER=1 firebase deploy",
    "deploy:api": "NO_UPDATE_NOTIFIER=1 firebase deploy --only functions --project catebydemo",
    "deploy:web": "NO_UPDATE_NOTIFIER=1 firebase deploy --only hosting --project catebydemo"
  },
  "devDependencies": {
    "firebase-tools": "^15.19.1"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  }
}
